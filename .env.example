# ── Anthropic ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Flask ──────────────────────────────────────────────────────────
FLASK_SECRET_KEY=change-me-to-any-random-string
FLASK_DEBUG=0

# Port — must match the proxy target in client/vite.config.ts (8000)
PORT=8000

# ── OAuth redirect URIs ────────────────────────────────────────────
# These are the URLs you register in each wearable's developer console.
# For local dev, leave these as-is.  For production, change the host.
API_HOST=http://localhost:8000
WHOOP_REDIRECT_URI=http://localhost:8000/api/whoop/callback
OURA_REDIRECT_URI=http://localhost:8000/api/oura/callback

# The Vite dev server origin (used for CORS)
FRONTEND_URL=http://localhost:5000

# ── WHOOP (optional — app works without it) ────────────────────────
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=

# ── Oura Ring (optional) ───────────────────────────────────────────
OURA_CLIENT_ID=
OURA_CLIENT_SECRET=

# ── SQLite database path ───────────────────────────────────────────
DB_PATH=apex.db
